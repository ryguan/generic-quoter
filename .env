# Kalshi API Credentials
# Copy this file to .env and fill in your values.
#
# To generate API credentials:
# 1. Log in at kalshi.com
# 2. Go to Settings -> API
# 3. Create a new key pair — download the private key (.pem file)
# 4. Copy the API Key ID shown on the page

KALSHI_API_KEY_ID=1d7feaf3-49fd-4f9b-b746-38bda2725ffb
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
